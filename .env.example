# GitHub Personal Access Token — needs read:org and repo scopes
GITHUB_TOKEN=ghp_your_token_here

# GitHub org and team to watch
GITHUB_ORG=DEFRA
GITHUB_TEAM=forms

# Jira ticket pattern (regex, without word boundaries) — used to extract ticket refs from PR titles/branches
# Default: DF-\d+
JIRA_TICKET_PATTERN=DF-\d+

# Base URL for Jira ticket links (no trailing slash)
# If omitted, ticket labels are shown as plain text rather than links
JIRA_BASE_URL=https://eaflood.atlassian.net/browse

# Public URL of this app — used in Slack message footers
# If omitted, no link is included in Slack messages
APP_URL=https://myurl.com

# Server port (default: 3000)
PORT=3000

# Cache TTL in milliseconds (default: 1200000 = 20 minutes)
CACHE_TTL_MS=1200000

# Slack integration (optional)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL_ID=C0123456789
